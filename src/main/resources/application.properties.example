spring.application.name=restaurante

# Configuración de la base de datos (ejemplo)
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.datasource.url=jdbc:mysql://localhost:3306/bd_restaurante2?useSSL=false&serverTimezone=UTC
spring.datasource.username=usuario
spring.datasource.password=contraseña

# Configuración de JPA/Hibernate
spring.jpa.hibernate.ddl-auto=none
spring.jpa.hibernate.naming.physical-strategy=org.hibernate.boot.model.naming.PhysicalNamingStrategyStandardImpl

# Mostrar las consultas SQL en la consola
spring.jpa.show-sql=true

# Inicializar la base de datos al arrancar la aplicación
spring.sql.init.mode=always

# Puerto del servidor
server.port=8080

# Perfil activo
spring.profiles.active=dev
